# Supabase (these are public/anon keys — safe to commit, but kept out of git for hygiene)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ConvertKit / Kit — paste your form ID from app.kit.com → Grow → Forms → (your form) → Embed
# The form ID is the number in the embed URL, e.g. https://app.kit.com/forms/12345/subscriptions
VITE_CONVERTKIT_FORM_ID=""
